{application,json_remedy,
             [{modules,['Elixir.JsonRemedy',
                        'Elixir.JsonRemedy.Context.ContextValues',
                        'Elixir.JsonRemedy.Context.JsonContext',
                        'Elixir.JsonRemedy.Layer1.ContentCleaning',
                        'Elixir.JsonRemedy.Layer2.StructuralRepair',
                        'Elixir.JsonRemedy.Layer3.BinaryProcessors',
                        'Elixir.JsonRemedy.Layer3.CharacterParsers',
                        'Elixir.JsonRemedy.Layer3.ContextManager',
                        'Elixir.JsonRemedy.Layer3.EllipsisFilter',
                        'Elixir.JsonRemedy.Layer3.HardcodedPatterns',
                        'Elixir.JsonRemedy.Layer3.HtmlHandlers',
                        'Elixir.JsonRemedy.Layer3.KeywordFilter',
                        'Elixir.JsonRemedy.Layer3.LiteralProcessors',
                        'Elixir.JsonRemedy.Layer3.ObjectMerger',
                        'Elixir.JsonRemedy.Layer3.Optimized.BinaryParser',
                        'Elixir.JsonRemedy.Layer3.Optimized.IOListBuilder',
                        'Elixir.JsonRemedy.Layer3.PostProcessors',
                        'Elixir.JsonRemedy.Layer3.QuoteProcessors',
                        'Elixir.JsonRemedy.Layer3.RuleProcessors',
                        'Elixir.JsonRemedy.Layer3.SyntaxDetectors',
                        'Elixir.JsonRemedy.Layer3.SyntaxHelpers',
                        'Elixir.JsonRemedy.Layer3.SyntaxNormalization',
                        'Elixir.JsonRemedy.Layer4.Validation',
                        'Elixir.JsonRemedy.LayerBehaviour',
                        'Elixir.JsonRemedy.Utils.CharUtils',
                        'Elixir.JsonRemedy.Utils.CodeFenceExtractor',
                        'Elixir.JsonRemedy.Utils.MultipleJsonDetector',
                        'Elixir.JsonRemedy.Utils.PlainTextDetector',
                        'Elixir.JsonRemedy.Utils.Preprocessing',
                        'Elixir.JsonRemedy.Utils.RepairPipeline',
                        'Elixir.JsonRemedy.Utils.StrictModeValidator',
                        'Elixir.JsonRemedy.Utils.StructureCoercion']},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,jason]},
              {description,"A blazingly fast Elixir library for repairing malformed JSON using binary pattern matching. Handles LLM outputs, legacy data, and broken JSON with intelligent context-aware fixes."},
              {registered,[]},
              {vsn,"0.2.1"}]}.
