{<<"name">>,<<"json_remedy">>}.
{<<"version">>,<<"0.2.1">>}.
{<<"description">>,
 <<"A blazingly fast Elixir library for repairing malformed JSON using binary pattern matching. Handles LLM outputs, legacy data, and broken JSON with intelligent context-aware fixes.">>}.
{<<"elixir">>,<<"~> 1.14">>}.
{<<"app">>,<<"json_remedy">>}.
{<<"licenses">>,[<<"MIT">>]}.
